---
import type { HeroProps } from "@types";
type Props = HeroProps;

const { name, specialty, summary, email } = Astro.props;
const linkedIn = "https://www.linkedin.com/in/nishanthanantha17";
---

<section class="py-24 md:py-32" id="#hero">
  <h1
    class="mb-1.5 font-serif text-7xl font-bold tracking-tightest text-white sm:text-8xl md:mb-0 md:text-9xl"
  >
    {name}
  </h1>
  <p
    class="mb-9 font-serif text-4xl leading-11.5 font-bold tracking-tighter text-primary sm:text-5xl md:text-6xl"
  >
    {specialty}
  </p>
  <p class="mb-16 text-base font-normal text-neutral md:text-lg">
    {summary}
  </p>

<div class="flex flex-wrap items-center gap-4">
  <a class="inline-block rounded-full bg-primary px-8 py-5 text-sm leading-5 font-medium text-[#fff]" href={`mailto:${email}`}>Email Me</a>
  <a class="inline-block rounded-full border border-white/25 px-8 py-5 text-sm leading-5 font-medium text-white/70 hover:border-white/50 hover:text-white transition-colors" href={linkedIn} target="_blank" rel="noopener noreferrer">LinkedIn</a>
</div>
</section>